{
  "trailingSlash": "never",
  "platform": {
    "apiRuntime": "node:22"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
  },
  "routes": [
    {
      "route": "/about",
      "rewrite": "/about.html"
    },
    {
      "route": "/services",
      "rewrite": "/services.html"
    },
    {
      "route": "/contact",
      "rewrite": "/contact.html"
    },
    {
      "route": "/repo-scan",
      "rewrite": "/repo-scan.html"
    },
    {
      "route": "/thank-you",
      "rewrite": "/thank-you.html"
    },
    {
      "route": "/owner-login",
      "rewrite": "/owner-login.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/login/aad",
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/owner-portal",
      "statusCode": 302
    },
    {
      "route": "/login/github",
      "redirect": "/.auth/login/github?post_login_redirect_uri=/owner-portal",
      "statusCode": 302
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout",
      "statusCode": 302
    },
    {
      "route": "/owner-portal*",
      "allowedRoles": ["owner"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/get-queries",
      "allowedRoles": ["owner"]
    },
    {
      "route": "/api/query-counts",
      "allowedRoles": ["owner"]
    },
    {
      "route": "/api/update-query",
      "allowedRoles": ["owner"]
    },
    {
      "route": "/api/user",
      "allowedRoles": ["authenticated"]
    }
  ]
}
